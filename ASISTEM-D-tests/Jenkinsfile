pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
    }

    tools {
        nodejs 'NodeJS-22'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Instalar dependencias') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm ci'
                }
            }
        }

        stage('Instalar Playwright browsers') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npx playwright install chromium'
                }
            }
        }

        stage('Ejecutar pruebas Serenity') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm test'
                }
            }
        }

        stage('Generar reporte Serenity') {
            when { expression { true } }
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm run serenity:report'
                }
            }
        }

        stage('Generar reporte HTML') {
            when { expression { true } }
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'node generate-report.js'
                }
            }
        }
    }

    post {
        always {
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'ASISTEM-D-tests/target/site/serenity',
                reportFiles: 'index.html',
                reportName: 'Serenity BDD Report'
            ])
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'ASISTEM-D-tests/target/site',
                reportFiles: 'cucumber-report.html',
                reportName: 'Cucumber HTML Report'
            ])
        }
        success {
            echo 'Pruebas ejecutadas correctamente'
        }
        failure {
            echo 'Algunas pruebas fallaron - revisar reporte'
        }
    }
}