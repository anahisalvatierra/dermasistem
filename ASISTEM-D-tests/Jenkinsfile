pipeline {
    agent any

    tools {
        nodejs 'NodeJS-22'
    }

    environment {
        PLAYWRIGHT_BROWSERS_PATH = 'C:\\ProgramData\\Jenkins\\playwright-browsers'
        PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD = '0'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Instalar dependencias') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm ci'
                }
            }
        }

        stage('Instalar Playwright browsers') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat '''
                        if not exist "C:\\ProgramData\\Jenkins\\playwright-browsers\\chromium*" (
                            echo Instalando Chromium por primera vez...
                            npx playwright install chromium
                        ) else (
                            echo Chromium ya instalado, saltando...
                        )
                    '''
                }
            }
        }

        stage('Ejecutar pruebas Serenity') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm test'
                }
            }
        }

        stage('Generar reporte Serenity') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm run serenity:report'
                }
            }
        }

        stage('Generar reporte HTML') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'node generate-report.js'
                }
            }
        }

        stage('Verificar archivos') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'dir target\\site\\serenity'
                }
            }
        }
    }

    post {
        always {
            script {
                System.setProperty("hudson.model.DirectoryBrowserSupport.CSP", "")
            }
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'ASISTEM-D-tests/target/site/serenity',
                reportFiles: 'index.html',
                reportName: 'Serenity BDD Report'
            ])
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'ASISTEM-D-tests/target/site',
                reportFiles: 'cucumber-report.html',
                reportName: 'Cucumber HTML Report'
            ])
        }
        success {
            echo '✅ Pruebas ejecutadas correctamente'
        }
        failure {
            echo '❌ Algunas pruebas fallaron - revisar reporte'
        }
    }
}