pipeline {
    agent any

    tools {
        nodejs 'NodeJS-22'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Instalar dependencias') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm ci'
                }
            }
        }

        stage('Instalar Playwright') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npx playwright install chromium'
                }
            }
        }

        stage('Ejecutar pruebas') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm test'
                }
            }
        }

        stage('Generar reporte Serenity') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'npm run serenity:report'
                }
            }
        }

        stage('Generar reporte HTML') {
            steps {
                dir('ASISTEM-D-tests') {
                    bat 'node generate-report.js'
                }
            }
        }
    }

    post {
        always {
            script {
                try {
                    System.setProperty("hudson.model.DirectoryBrowserSupport.CSP", "")
                } catch (Exception e) {
                    echo "CSP property ya configurada: ${e.message}"
                }
            }
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'ASISTEM-D-tests/target/site/serenity',
                reportFiles: 'index.html',
                reportName: 'Serenity BDD Report'
            ])
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'ASISTEM-D-tests/target/site',
                reportFiles: 'cucumber-report.html',
                reportName: 'Cucumber HTML Report'
            ])
        }
        success {
            echo '✅ Pruebas ejecutadas correctamente'
        }
        failure {
            echo '❌ Algunas pruebas fallaron'
        }
    }
}